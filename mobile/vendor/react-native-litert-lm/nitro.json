{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["litertlm"],
  "ios": {
    "iosModuleName": "LiteRTLM",
    "language": "c++"
  },
  "android": {
    "androidNamespace": ["dev", "litert", "litertlm"],
    "androidCxxLibName": "LiteRTLM",
    "language": "kotlin"
  },
  "autolinking": {
    "LiteRTLM": {
      "ios": { "language": "c++", "implementationClassName": "HybridLiteRTLM" },
      "android": { "language": "kotlin", "implementationClassName": "HybridLiteRTLM" }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
