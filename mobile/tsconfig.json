{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/lib/prompts/*": ["./src/prompts/*"],
      "@/lib/session/*": ["./src/session/*"],
      "@/lib/training/*": ["./src/prompts/*"],
      "@/lib/voice/*": ["./src/voice/*"],
      "@/lib/gemma/*": ["./src/gemma/*"],
      "@/lib/wllama/*": ["./src/runtime/*"],
      "@/types/*": ["./src/types/*"],
      "@/*": ["./src/*", "./*"],
      "whisper.rn": ["./node_modules/whisper.rn/lib/typescript/index.d.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ]
}
